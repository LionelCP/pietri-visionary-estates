# =====================================================================
# Cabinet Pietri Immobilier — variables d'environnement (modèle)
# =====================================================================
# Copier ce fichier en `.env` à la racine du projet. Sur Lovable Cloud,
# le `.env` est rempli automatiquement à l'ouverture du projet.
#
# ⚠️ Les variables préfixées VITE_ sont EMBARQUÉES DANS LE BUNDLE
# CLIENT. Ne jamais y mettre de secret. Les clés `anon/publishable`
# de Supabase sont publiques par design (la sécurité repose sur RLS).
# =====================================================================

# --- Client (Vite) ---------------------------------------------------
# URL du projet Supabase (Lovable Cloud)
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"

# Clé anon / publishable (publique, RLS obligatoire côté DB)
VITE_SUPABASE_PUBLISHABLE_KEY="<publishable-key>"

# Référence du projet Supabase (utilisée par le serveur MCP)
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# =====================================================================
# Variables serveur (Edge Functions) — gérées automatiquement par
# Lovable Cloud, non modifiables via ce fichier :
#   - SUPABASE_URL
#   - SUPABASE_PUBLISHABLE_KEY
#   - SUPABASE_ANON_KEY
#   - SUPABASE_SERVICE_ROLE_KEY   (secret — jamais exposée au client)
#   - SUPABASE_JWKS
#   - SUPABASE_DB_URL             (secret)
#   - LOVABLE_API_KEY             (secret — Lovable AI Gateway)
# =====================================================================
